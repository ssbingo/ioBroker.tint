{
	"name": "iobroker.tint",
	"version": "0.4.5",
	"description": "Müller Licht Tint Steuerung via deCONZ/ConBee",
	"author": {
		"name": "ssbingo",
		"email": "s.sternitzke@online.de"
	},
	"contributors": [],
	"homepage": "https://github.com/ssbingo/ioBroker.tint",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"MüllerLicht",
		"Tint",
		"Zigbee",
		"deCONZ",
		"ConBee",
		"RGBW"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ssbingo/ioBroker.tint.git"
	},
	"engines": {
		"node": ">= 22"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.4.1",
		"axios": "^1.7.7",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.2.1",
		"@alcalzone/release-script-plugin-iobroker": "^5.2.0",
		"@alcalzone/release-script-plugin-license": "^5.2.0",
		"@alcalzone/release-script-plugin-manual-review": "^5.2.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@iobroker/adapter-dev": "^1.5.0",
		"@iobroker/eslint-config": "^2.3.4",
		"@iobroker/socket-client": "^5.2.1",
		"@iobroker/testing": "^5.2.2",
		"@module-federation/vite": "^1.16.8",
		"@mui/material": "^9.1.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/iobroker": "npm:@iobroker/types@^7.2.2",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	},
	"main": "main.js",
	"files": [
		"admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
		"admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
		"admin/build/",
		"lib/",
		"www/",
		"io-package.json",
		"LICENSE",
		"main.js"
	],
	"scripts": {
		"prebuild": "rimraf admin/build",
		"build": "npm run build:panels && npm run build:tab",
		"watch": "vite build --config admin/vite.config.mjs --watch",
		"build:panels": "vite build --config admin/vite.config.mjs",
		"build:tab": "vite build --config admin/vite.config.tab.mjs",
		"test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
		"test:package": "mocha test/package --exit",
		"test:integration": "mocha test/integration --exit",
		"test": "npm run test:js && npm run test:package",
		"check": "tsc --noEmit -p tsconfig.check.json",
		"lint": "eslint -c eslint.config.mjs .",
		"translate": "translate-adapter",
		"release": "release-script"
	},
	"bugs": {
		"url": "https://github.com/ssbingo/ioBroker.tint/issues"
	},
	"readmeFilename": "README.md"
}
