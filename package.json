{
	"name": "iobroker.tint",
	"version": "0.2.4",
	"description": "Müller Licht Tint Steuerung via deCONZ/ConBee",
	"author": {
		"name": "ssbingo",
		"email": "s.sternitzke@online.de"
	},
	"contributors": [],
	"homepage": "https://github.com/ssbingo/ioBroker.tint",
	"license": "MIT",
	"keywords": [
		"MüllerLicht",
		"Tint",
		"Zigbee",
		"deCONZ",
		"ConBee",
		"RGBW"
	],
	"repository": {
		"type": "git",
		"url": "git@github.com:ssbingo/ioBroker.tint.git"
	},
	"engines": {
		"node": ">= 22"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.4.1",
		"axios": "^1.7.7",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.2.1",
		"@alcalzone/release-script-plugin-iobroker": "^5.2.0",
		"@alcalzone/release-script-plugin-license": "^5.2.0",
		"@alcalzone/release-script-plugin-manual-review": "^5.2.0",
		"@iobroker/adapter-dev": "^1.5.0",
		"@iobroker/adapter-react": "2.0.22",
		"@iobroker/eslint-config": "^2.3.4",
		"@iobroker/testing": "^5.2.2",
		"@material-ui/core": "^4.12.4",
		"@tsconfig/node20": "^20.1.9",
		"@types/iobroker": "npm:@iobroker/types@^7.2.1",
		"@types/node": "^20.19.43",
		"@types/react": "^17.0.93",
		"@types/react-dom": "^17.0.26",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"typescript": "~5.9.3"
	},
	"main": "main.js",
	"files": [
		"admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
		"admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
		"admin/build/",
		"lib/",
		"www/",
		"io-package.json",
		"LICENSE",
		"main.js"
	],
	"scripts": {
		"prebuild": "rimraf admin/build",
		"build": "build-adapter react && npm run build:panels",
		"watch": "build-adapter react --watch",
		"prebuild:react": "rimraf admin/build",
		"build:react": "build-adapter react",
		"watch:react": "build-adapter react --watch",
		"build:panels": "mkdir -p admin/build/panels && esbuild admin/src/panels/LightsPanel.jsx admin/src/panels/GroupsPanel.jsx --bundle --format=iife --platform=browser --define:process.env.NODE_ENV=\\\"production\\\" --outdir=admin/build/panels",
		"test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
		"test:package": "mocha test/package --exit",
		"test:integration": "mocha test/integration --exit",
		"test": "npm run test:js && npm run test:package",
		"check": "tsc --noEmit -p tsconfig.check.json",
		"lint": "eslint -c eslint.config.mjs .",
		"translate": "translate-adapter",
		"release": "release-script"
	},
	"bugs": {
		"url": "https://github.com/ssbingo/ioBroker.tint/issues"
	},
	"readmeFilename": "README.md"
}
