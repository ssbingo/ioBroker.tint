// Specialized tsconfig for type-checking js files
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		// TS6 tightened null analysis in JS files; disable until main.js null guards are complete
		"strictNullChecks": false,
		// Provide mocha globals (describe, it, before, after) for test files
		"types": ["node", "mocha"]
	},
	"include": ["**/*.js", "**/*.d.ts"],
	"exclude": [
		"**/build",
		"node_modules/",
		"widgets/",
		// admin/src contains JSX/React files checked by vite, not this Node.js tsconfig
		"admin/src/**"
	]
}
